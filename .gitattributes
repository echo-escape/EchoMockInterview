# Enforce LF line endings for all text files
* text=auto

# Explicitly set LF for common source types and scripts
*.py text eol=lf
*.sh text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
docker-compose.yml text eol=lf
Dockerfile text eol=lf
devcontainer.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.wav binary
*.mp3 binary
*.zip binary
