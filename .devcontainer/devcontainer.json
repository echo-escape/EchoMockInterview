{
  "name": "EchoMockInterview Dev Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/app",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "forwardPorts": [8000, 5173],
  "postCreateCommand": "echo 'Dev container ready' && if [ -f /app/scripts/init_db.py ]; then python /app/scripts/init_db.py; else echo 'No init_db.py found, skipping database init'; fi",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false
      }
    }
  }
}