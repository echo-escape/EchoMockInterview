*.swp
*.swo

# ==================================
# Vector Store / Data 
# ==================================
# Ignore vector database index files
data/vector_store/
# ALLOW raw question data (source of truth)
!data/raw/
# Ignore SQLite databases and log files
*.sqlite3
*.db
*.db-shm
*.db-wal
data/*.db*

# ==================================
# Logs
# ==================================
logs/
*.log

# ==================================
# Docker
# ==================================
# Ignore docker volume mounts usually located locally
.docker/
